# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout
*.py text
*.js text
*.html text
*.css text
*.json text
*.md text
*.yml text
*.yaml text
*.xml text
*.txt text
*.sql text
*.sh text
*.bat text
*.ps1 text

# Declare files that will always have CRLF line endings on checkout
*.sln text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pyc binary
*.pyd binary
*.so binary
*.dll binary
*.exe binary
*.dmg binary
*.pkg binary
